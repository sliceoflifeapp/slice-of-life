{
  "name": "slice-of-life",
  "version": "0.1.34",
  "description": "Personal video journal maker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "GATHER_DEV=1 electron .",
    "build": "electron-builder --mac dmg"
  },
  "author": "Slice of Life",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@tabler/icons-webfont": "^3.24.0",
    "busboy": "^1.6.0",
    "exiftool-vendored": "^28.3.0",
    "express": "^4.21.0",
    "ffmpeg-static": "^5.2.0",
    "nodejs-whisper": "^0.3.0",
    "posthog-node": "^5.34.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "app.sliceoflife.app",
    "productName": "Slice of Life",
    "copyright": "Copyright © 2026 Slice of Life",
    "mac": {
      "category": "public.app-category.photography",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "entitlementsInherit": "entitlements.mac.plist",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Slice of Life",
      "artifactName": "Slice-of-Life.dmg",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "ui/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/.cache/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "node_modules/exiftool-vendored.exe/**/*",
      "node_modules/exiftool-vendored.pl/**/*",
      "node_modules/sql.js/**/*",
      "node_modules/nodejs-whisper/**/*",
      "assets/fonts/**/*",
      "server/bin/**/*"
    ]
  }
}
