{
  "name": "slice-of-life",
  "version": "0.1.37",
  "description": "Personal video journal maker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "GATHER_DEV=1 electron .",
    "build": "electron-builder --mac dmg"
  },
  "author": "Slice of Life",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@tabler/icons-webfont": "^3.24.0",
    "busboy": "^1.6.0",
    "exiftool-vendored": "^28.3.0",
    "express": "^4.21.0",
    "ffmpeg-static": "^5.2.0",
    "nodejs-whisper": "^0.3.0",
    "posthog-node": "^5.34.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^39.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "app.sliceoflife.app",
    "productName": "Slice of Life",
    "copyright": "Copyright © 2026 Slice of Life",
    "afterSign": "scripts/notarize.js",
    "afterPack": "scripts/sign-natives.js",
    "mac": {
      "category": "public.app-category.photography",
      "icon": "build/icon.icns",
      "identity": "NATHANIEL CALEM GRIFFEY (JRR5JMZ59T)",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Slice of Life",
      "artifactName": "Slice-of-Life.dmg",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "server/**/*",
      "ui/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/nodejs-whisper/cpp/whisper.cpp/build/CMakeFiles/**/*",
      "!node_modules/nodejs-whisper/cpp/whisper.cpp/build/CMakeFiles",
      "!node_modules/nodejs-whisper/cpp/whisper.cpp/build/bin/bench",
      "!node_modules/nodejs-whisper/cpp/whisper.cpp/build/bin/main",
      "!node_modules/nodejs-whisper/cpp/whisper.cpp/build/bin/test-vad",
      "!node_modules/nodejs-whisper/cpp/whisper.cpp/build/bin/test-vad-full",
      "!node_modules/nodejs-whisper/cpp/whisper.cpp/build/bin/vad-speech-segments",
      "!node_modules/nodejs-whisper/cpp/whisper.cpp/build/bin/whisper-bench",
      "!node_modules/nodejs-whisper/cpp/whisper.cpp/build/bin/whisper-server"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "node_modules/exiftool-vendored.exe/**/*",
      "node_modules/exiftool-vendored.pl/**/*",
      "node_modules/sql.js/**/*",
      "node_modules/nodejs-whisper/**/*",
      "assets/fonts/**/*",
      "server/bin/**/*"
    ]
  }
}
